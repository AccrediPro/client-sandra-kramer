---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import CTA from '../components/sections/CTA.astro';
import { cn } from '../lib/utils';
import { siteConfig } from '../config/siteConfig';

const coachName = siteConfig.coach.name;
const coachTitle = siteConfig.coach.title;
const storyParagraphs = siteConfig.bio.storyParagraphs;
const differentiator = siteConfig.bio.differentiator;
const certifications = siteConfig.certifications;
const holisticAspects = siteConfig.bio.holisticAspects;
---

<BaseLayout
  title={`About ${coachName} | ${coachTitle}`}
  description={`Learn about ${coachName}, ${coachTitle}. Discover my personal journey from health struggles to helping others find root-cause solutions through functional medicine.`}
  page="about"
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative py-14 md:py-24 bg-gradient-to-br from-secondary-50 via-white to-primary-50 overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100 rounded-full opacity-30 blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-100 rounded-full opacity-30 blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Image Column -->
        <div class="flex justify-center lg:justify-start order-2 lg:order-1" data-aos="fade-right">
          <div class="relative mx-8 sm:mx-12 lg:mx-0">
            <!-- Decorative background shapes -->
            <div class="absolute -top-5 -left-5 w-full h-full rounded-2xl transform -rotate-3" style="background-color: rgba(122,158,126,0.35);"></div>
            <div class="absolute -bottom-5 -right-5 w-full h-full rounded-2xl transform rotate-3" style="background-color: rgba(232,180,184,0.25);"></div>

            <!-- Wellness imagery -->
            <img
              src={siteConfig.images.portrait}
              alt="Natural wellness and functional medicine representing Sandra Kramer's holistic approach"
              width="1024" height="1024"
              decoding="async"
              class="relative w-56 sm:w-72 md:w-80 lg:w-96 rounded-2xl shadow-2xl ring-4 ring-white"
              style="display: block; width: 100%; height: auto; object-fit: cover; aspect-ratio: 4/5;"
              loading="eager"
            />

            <!-- Floating credential badge -->
            <div class="absolute -bottom-4 -right-4 rounded-xl px-4 py-3 shadow-lg text-center" style="background-color: #3b5540;">
              <p class="font-heading font-bold text-2xl leading-none" style="color: #E8B4B8;">IHMC</p>
              <p class="font-body text-xs mt-0.5" style="color: #e0ede2;">Certified</p>
            </div>
          </div>
        </div>

        <!-- Content Column -->
        <div class="order-1 lg:order-2" data-aos="fade-left" data-aos-delay="100">
          <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
            About Me
          </span>

          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-primary-900 leading-tight">
            Hi, I'm {coachName.split(' ')[0]}
          </h1>

          <p class="mt-2 text-xl md:text-2xl text-primary-600 font-heading font-medium">
            {coachTitle}
          </p>

          <div class="mt-6 space-y-4">
            {storyParagraphs.map((paragraph) => (
              <p class="text-lg font-body" style="color: #3a3a3a; line-height: 1.7;">
                {paragraph}
              </p>
            ))}
          </div>

          <!-- Quick stats -->
          <div class="mt-8 flex flex-wrap gap-6">
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-heading font-bold text-primary-600">1</p>
              <p class="text-sm text-gray-600 font-body">Certification</p>
            </div>
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-heading font-bold text-primary-600">12</p>
              <p class="text-sm text-gray-600 font-body">Week Program</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Me Different Section -->
  <section id="method" class="py-14 md:py-24 bg-secondary-50" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          My Approach
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900">
          What Makes Me Different
        </h2>
        <p class="mt-6 text-lg text-gray-700 font-body leading-relaxed">
          {differentiator}
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-md">
          <h3 class="text-xl font-heading font-semibold text-primary-900 mb-4">
            I Help Clients With Issues Doctors Can't Explain
          </h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700 font-body">Fatigue with no real reason that doctors cannot define</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700 font-body">A persistent cough that cannot be explained and no prescription works</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700 font-body">Insomnia and no one can figure out why</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700 font-body">Any ongoing health issue where a pill may not be the answer</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications Section -->
  <section class="py-14 md:py-24 bg-white" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Credentials
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900">
          My Certification
        </h2>
        <p class="mt-4 text-lg text-gray-700 font-body">
          I bring specialized training in integrated health and functional medicine to help you find root-cause solutions.
        </p>
      </div>

      <div class="flex justify-center max-w-5xl mx-auto">
        {certifications.map((cert, index) => (
          <div
            class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow duration-300 text-center max-w-sm"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="mb-4">
              <Badge variant={cert.variant} class="text-base px-4 py-2">
                {cert.label}
              </Badge>
            </div>
            <h3 class="text-lg font-heading font-semibold text-primary-900 mb-2">
              {cert.title}
            </h3>
            <p class="text-sm text-gray-600 font-body">
              {cert.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Holistic Approach Section -->
  <section class="py-14 md:py-24 bg-secondary-50" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
              My Philosophy
            </span>
            <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 leading-tight">
              A Holistic Approach to Lasting Health
            </h2>
            <div class="mt-6 space-y-4 text-lg text-gray-700 font-body leading-relaxed">
              <p>
                I believe that true healing begins with understanding the root cause — not just masking symptoms with medication. My journey through the traditional medical system taught me that sometimes the answers lie outside conventional approaches.
              </p>
              <p>
                Through functional medicine, I help you look at the whole picture and find solutions that address what's really going on in your body.
              </p>
            </div>

            <!-- Holistic Aspects -->
            <div class="mt-8 flex flex-wrap gap-3">
              {holisticAspects.map((aspect) => (
                <span class="inline-flex items-center px-4 py-2 rounded-full bg-primary-50 text-primary-700 font-medium text-sm border border-primary-200">
                  {aspect}
                </span>
              ))}
            </div>
          </div>

          <div class="flex justify-center">
            <div class="relative rounded-2xl overflow-hidden shadow-xl w-full max-w-sm">
              <img
                src="/images/unsplash/wellness-1.jpg"
                alt="Holistic wellness and natural healing — representing Sandra Kramer's functional medicine approach"
                width="1080" height="720"
                decoding="async"
                class="w-full object-cover"
                style="aspect-ratio: 4/3;"
                loading="lazy"
              />
              <!-- Overlaid quote -->
              <div class="absolute inset-0 flex items-end" style="background: linear-gradient(to top, rgba(59,85,64,0.85) 50%, transparent 100%);">
                <blockquote class="p-6">
                  <p class="text-base font-heading font-medium italic leading-snug" style="color: #faf6ef;">
                    "{siteConfig.bio.holisticQuote}"
                  </p>
                  <footer class="mt-2">
                    <p class="text-sm font-body font-semibold" style="color: #E8B4B8;">— {siteConfig.coach.name}</p>
                  </footer>
                </blockquote>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />

  <Footer slot="footer" />
</BaseLayout>
