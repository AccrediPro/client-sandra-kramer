---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import CTA from '../components/sections/CTA.astro';
import { siteConfig } from '../config/siteConfig';

const services = siteConfig.servicesDetail;

---

<BaseLayout
  title={`Services | ${siteConfig.coach.name} - ${siteConfig.coach.title}`}
  description={`${siteConfig.coach.name}'s A Holistic Reset Program: 12 weekly video calls, email support, and a comprehensive workbook — a 3-month functional medicine coaching program.`}
  page="services"
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative py-14 md:py-24 bg-gradient-to-br from-secondary-50 via-white to-primary-50 overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100 rounded-full opacity-30 blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-100 rounded-full opacity-30 blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          How I Can Help
        </span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-tight text-primary-900" style="letter-spacing: -0.02em; line-height: 1.1;">
          Programs to <span class="text-primary-600">Reclaim Your Health</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl font-body" style="color: #3a3a3a; line-height: 1.7;">
          I help clients who have ongoing health issues that doctors have not been able to diagnose. Through functional medicine, we work together to uncover root causes and find lasting solutions.
        </p>

        <!-- Delivery Methods -->
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <span class="inline-flex items-center gap-2 bg-white rounded-full px-4 py-2 text-sm font-medium text-primary-700 shadow-sm border border-primary-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
            Video Calls
          </span>
          <span class="inline-flex items-center gap-2 bg-white rounded-full px-4 py-2 text-sm font-medium text-primary-700 shadow-sm border border-primary-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
            Email Support
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Visual Banner -->
  <div class="relative overflow-hidden">
    <img
      src="/images/unsplash/wellness-1.jpg"
      alt="Wellness and functional medicine — a holistic approach to health"
      width="1080"
      height="608"
      class="w-full"
      style="display: block; height: auto;"
      loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 50%, rgba(255,255,255,1) 100%);"></div>
  </div>

  <!-- Services Detail Section -->
  <section class="pt-6 pb-14 md:pb-24 bg-white">
    <div class="container mx-auto px-4">
      {services.map((service, index) => (
        <div
          id={service.id}
          class={`py-12 ${index !== 0 ? 'border-t border-gray-100' : ''}`}
          data-aos="fade-up"
        >
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start max-w-6xl mx-auto">
            <!-- Content Side -->
            <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="text-primary-500 mb-4">
                <Fragment set:html={service.icon} />
              </div>
              <div class="flex items-center gap-3 mb-2">
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary-900">
                  {service.title}
                </h2>
                <span class={`inline-block rounded-full px-3 py-1 text-sm font-bold ${service.price === 'FREE' ? 'bg-accent-100 text-accent-800' : 'bg-primary-100 text-primary-800'}`}>
                  {service.price}
                </span>
              </div>
              <p class="font-medium mb-1 text-primary-800">
                {service.subtitle}
              </p>
              <p class="text-sm text-gray-600 font-body mb-4">
                {service.duration}
              </p>
              <p class="text-lg font-body mb-6" style="color: #3a3a3a; line-height: 1.7;">
                {service.description}
              </p>

              <div class="bg-accent-50 rounded-lg p-4 mb-6">
                <p class="text-sm font-medium text-accent-700">
                  <span class="font-semibold">Ideal for:</span> {service.idealFor}
                </p>
              </div>

              <Button href="/contact" variant="primary">
                {service.price === 'FREE' ? 'Book Your Free Call' : 'Get Started'}
              </Button>
            </div>

            <!-- Features Side -->
            <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
              <Card class="h-full">
                <h3 class="text-lg font-heading font-semibold text-primary-900 mb-4">
                  What's Included
                </h3>
                <ul class="space-y-3">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="font-body" style="color: #3a3a3a;">{feature}</span>
                    </li>
                  ))}
                </ul>
              </Card>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing Comparison Section -->
  <section class="py-14 md:py-24 bg-secondary-50" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Investment in Your Health
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900">
          Transparent Pricing
        </h2>
        <p class="mt-4 text-lg text-gray-700 font-body">
          Start with a free discovery call. When you're ready, the Holistic Reset Program gives you everything you need.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8 max-w-4xl mx-auto">
        <!-- Free Call -->
        <Card class="text-center relative">
          <div class="mb-4">
            <span class="inline-block bg-accent-100 text-accent-800 text-xs font-bold uppercase tracking-wider rounded-full px-3 py-1">
              Start Here
            </span>
          </div>
          <h3 class="text-xl font-heading font-semibold text-primary-900 mb-2">
            Discovery Call
          </h3>
          <div class="text-4xl font-heading font-bold text-primary-600 mb-1">
            FREE
          </div>
          <p class="text-sm text-gray-600 mb-6">No commitment required</p>
          <ul class="text-left space-y-2 mb-6">
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Discuss your health concerns
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Determine if we're a good fit
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              No obligation
            </li>
          </ul>
          <Button href="/contact" variant="secondary" class="w-full">
            Book Your Free Call
          </Button>
        </Card>

        <!-- Holistic Reset -->
        <Card class="text-center relative ring-2 ring-primary-500 shadow-lg">
          <div class="mb-4">
            <span class="inline-block bg-primary-600 text-white text-xs font-bold uppercase tracking-wider rounded-full px-3 py-1">
              Signature Program
            </span>
          </div>
          <h3 class="text-xl font-heading font-semibold text-primary-900 mb-2">
            A Holistic Reset Program
          </h3>
          <div class="text-4xl font-heading font-bold text-primary-600 mb-1">
            $3,000
          </div>
          <p class="text-sm text-gray-600 mb-6">3 months (12 weekly sessions)</p>
          <ul class="text-left space-y-2 mb-6">
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              12 weekly video coaching calls
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Email support throughout
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Comprehensive workbook
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Root-cause functional medicine approach
            </li>
          </ul>
          <Button href="/contact" variant="primary" class="w-full">
            Get Started
          </Button>
        </Card>
      </div>
    </div>
  </section>

  <!-- FAQ Preview -->
  <section class="py-14 md:py-24 bg-white" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Questions?
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-6">
          Have Questions About My Program?
        </h2>
        <p class="text-lg text-gray-700 font-body mb-8">
          Check out my frequently asked questions or reach out directly. Your discovery call is always free — no obligation, no pressure.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/#faq" variant="secondary" size="lg">
            View FAQ
          </Button>
          <Button href="/contact" variant="primary" size="lg">
            Book Your Free Call
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />

  <Footer slot="footer" />
</BaseLayout>
